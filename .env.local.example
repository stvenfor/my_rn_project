# 语雀 Cookie 配置（在项目根目录复制为 .env.local，勿提交 Git）
#
# 推荐：在数据目录 /Users/mac/Desktop/yuque 下配置并执行命令：
#   cd /Users/mac/Desktop/yuque && cp .env.local.example .env.local
#   npm run auth && npm run sync-all && npm run run-all
#
# cp .env.local.example .env.local   # 在 my_rn_project 根目录执行（备选）
#
# 获取 Cookie：浏览器登录 yuque.com → F12 → Application → Cookies
# 推荐复制完整 Cookie 字符串：
#   lang=zh-cn; _yuque_session=xxx; yuque_ctoken=xxx

# 语雀文档本地目录（导出、优化、备份均在此）
YUQUE_DATA_DIR=/Users/mac/Desktop/yuque

# 方式一：仅 session（最小配置）
YUQUE_COOKIE=your_yuque_session_value

# 方式二：完整 Cookie（推荐，写回时需要 yuque_ctoken）
# 须包含 _yuque_session 和 yuque_ctoken，例如：
# YUQUE_COOKIE_FULL=lang=zh-cn; _yuque_session=xxx; yuque_ctoken=xxx

# 可选：单独指定 CSRF token（与 yuque_ctoken 相同）
# YUQUE_CSRF_TOKEN=your_ctoken_value

# 单库同步时的目标知识库 URL（--all 同步所有库时可忽略）
YUQUE_REPO_URL=https://www.yuque.com/hanshihuanyan/eav1v0

# 可选：覆盖解析出的 group/book
# YUQUE_GROUP=hanshihuanyan
# YUQUE_BOOK=eav1v0
