{
  "name": "my-rn-lego-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/core/*",
    "packages/features/*",
    "packages/ui/*",
    "packages/commons/*"
  ],
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint App.tsx src packages --ext .ts,.tsx",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "dev": "react-native bundle-harmony --dev",
    "harmony": "react-native run-harmony",
    "harmony:patch": "node scripts/patch-harmony-rnoh-packages.js",
    "codegen": "react-native codegen-harmony --cpp-output-path ./harmony/entry/src/main/cpp/generated --rnoh-module-path ./harmony/entry/oh_modules/@rnoh/react-native-openharmony",
    "link:harmony": "react-native link-harmony",
    "sync:app-shell-assets": "node scripts/sync-app-shell-assets.js",
    "sync:web-assets": "node scripts/sync-web-assets.js",
    "postinstall": "node scripts/patch-boost-podspec.js && node scripts/patch-yoga-ygvalue.js && node scripts/patch-harmony-rnoh-packages.js && node scripts/patch-rn-harmony-stubs.js",
    "pod:install": "node scripts/pod-install-ios.js",
    "yuque:auth": "bash scripts/yuque/check-auth.sh",
    "yuque:sync": "node scripts/yuque/sync.mjs",
    "yuque:sync-all": "node scripts/yuque/sync.mjs -- --all",
    "yuque:inventory": "node scripts/yuque/build-inventory.mjs",
    "yuque:optimize": "node scripts/yuque/optimize-rules.mjs",
    "yuque:backup": "node scripts/yuque/backup.mjs",
    "yuque:diff": "node scripts/yuque/generate-diff.mjs",
    "yuque:push": "node scripts/yuque/push-all.mjs",
    "yuque:pilot": "node scripts/yuque/pilot.mjs",
    "yuque:run-all": "node scripts/yuque/run-all.mjs"
  },
  "dependencies": {
    "@commons/toolkit": "*",
    "@core/api-client": "*",
    "@core/bluetooth": "*",
    "@core/config": "*",
    "@core/domain": "*",
    "@core/i18n": "*",
    "@core/im": "*",
    "@core/linking": "*",
    "@core/media-picker": "*",
    "@core/media-player": "*",
    "@core/navigation": "*",
    "@core/permissions": "*",
    "@core/realtime": "*",
    "@core/storage": "*",
    "@core/supabase": "*",
    "@core/webview": "*",
    "@features/auth": "*",
    "@features/bfui": "*",
    "@features/chat": "*",
    "@features/community": "*",
    "@features/friend": "*",
    "@features/home": "*",
    "@features/live": "*",
    "@features/music": "*",
    "@features/pay": "*",
    "@features/settings": "*",
    "@features/video": "*",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/slider": "^4.5.7",
    "@react-native-oh/react-native-harmony": "0.72.140",
    "@react-native-oh/react-native-harmony-cli": "0.72.140",
    "@react-native-ohos/async-storage": "1.21.1",
    "@react-native-ohos/react-native-gesture-handler": "2.14.18",
    "@react-native-ohos/react-native-image-picker": "8.2.4",
    "@react-native-ohos/react-native-safe-area-context": "4.7.5",
    "@react-native-ohos/react-native-screens": "3.34.1",
    "@react-native-ohos/react-native-track-player": "^4.1.3",
    "@react-native-ohos/react-native-video": "^6.13.2-rc.1",
    "@react-native-ohos/react-native-webview": "^13.10.5",
    "@react-native-ohos/stack": "6.4.1-1.rc.1",
    "@react-navigation/bottom-tabs": "6.5.20",
    "@react-navigation/native": "6.1.17",
    "@reduxjs/toolkit": "2.2.7",
    "@ui/design-system": "*",
    "axios": "1.7.7",
    "i18next": "23.15.1",
    "react": "18.2.0",
    "react-i18next": "15.0.2",
    "react-native": "0.72.5",
    "react-native-gesture-handler": "2.14.1",
    "react-native-image-picker": "7.1.2",
    "react-native-safe-area-context": "4.7.4",
    "react-native-screens": "3.34.0",
    "react-native-shared-element": "^0.8.9",
    "react-native-track-player": "^4.1.1",
    "react-native-video": "^6.13.0",
    "react-native-webview": "^13.10.5",
    "react-navigation-shared-element": "^3.1.3",
    "react-redux": "9.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "js-yaml": "^5.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.3",
    "yuque-dl": "^1.0.85"
  },
  "engines": {
    "node": ">=16"
  }
}
