      { "pdf_concept": "诚实完成态", "repo": "Migrated|Degraded|Placeholder|Deferred|Removed" },
      { "pdf_concept": "双事实源", "repo": "08-acceptance.md + parity-manifest" },
      { "pdf_concept": "人类闸门", "repo": "Brief 定范围；降级决策；显式要求才 commit/push" }
    ]
  }
