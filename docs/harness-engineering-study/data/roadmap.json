    { "name": "SWE-agent", "stars": "15k+", "type": "CLI Agent", "best_for": "自动修 GitHub Issue", "harness": 3 },
    { "name": "Superpowers", "stars": "127k", "type": "技能框架", "best_for": "强制 TDD + 子 Agent", "harness": 5 },
    { "name": "Cursor / Codex", "stars": "-", "type": "IDE/Agent", "best_for": "生产开发日常", "harness": 5 }
  ],
