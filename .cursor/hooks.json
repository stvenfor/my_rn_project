{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-start.mjs",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/before-submit-prompt.mjs",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/after-file-edit.mjs",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop.mjs",
        "timeout": 10,
        "loop_limit": 1
      }
    ]
  }
}
